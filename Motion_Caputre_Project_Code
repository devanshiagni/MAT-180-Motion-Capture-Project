        "\n",
        "    # Store PCA models\n",
        "    pca_models[name] = pca\n",
        "\n",
        "    # projections stored as DataFrame\n",
        "    df = pd.DataFrame(transformed, columns=[f\"PC{i+1}\" for i in range(transformed.shape[1])])\n",
        "    pca_dataframes[name] = df\n",
        "\n",
        "    # Store cumulative variance\n",
        "    cumulative_variances[name] = np.cumsum(pca.explained_variance_ratio_)\n",
