        "#  Scatter plots of PC1 vs PC2\n",
        "for name, df in pca_dataframes.items():\n",
        "    plt.figure(figsize=(6,5))\n",
        "    plt.scatter(df['PC1'], df['PC2'], s=10)\n",
        "    plt.xlabel(\"PC1\")\n",
        "    plt.ylabel(\"PC2\")\n",
        "    plt.title(f\"PCA Projection: {name}\")\n",
        "    plt.show()\n",
        "\n",
        "#  Scree plots\n",
        "for name, pca in pca_models.items():\n",
        "    plt.figure(figsize=(6,5))\n",
        "    plt.plot(range(1, len(pca.explained_variance_ratio_)+1), pca.explained_variance_ratio_, marker='o')\n",
